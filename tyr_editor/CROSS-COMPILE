sudo dpkg --add-architecture i386
sudo mkdir -pm755 /etc/apt/keyrings
wget -O - https://dl.winehq.org/wine-builds/winehq.key | sudo gpg --dearmor -o /etc/apt/keyrings/winehq-archive.key -
sudo wget -NP /etc/apt/sources.list.d/ https://dl.winehq.org/wine-builds/ubuntu/dists/noble/winehq-noble.sources
sudo apt update && sudo apt install --install-recommends winehq-stable
sudo apt install libasound2-plugins:i386 libsdl2-2.0-0:i386 libdbus-1-3:i386 libsqlite3-0:i386 winetricks
winetricks corefonts vcrun2022 dotnet48 

wget https://www.python.org/ftp/python/3.11.9/python-3.11.9-amd64.exe
wine python-3.11.9-amd64.exe
wine pip install PyQt5 pyqtgraph numpy pyinstaller scipy
mkdir $HOME/.wine/drive_c/tyr_editor
cp -R ./* $HOME/.wine/drive_c/tyr_editor
cd $HOME/.wine/drive_c/tyr_editor 
wine python -m PyInstaller --onefile --windowed tyr_editor.py
